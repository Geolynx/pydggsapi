# PyDGGS API Environment Configuration

# If using 'full' or 'dggrid' feature in Pixi, DGGRID_PATH is automatically in the environment.
# For 'lean' environment, uncomment and point to your custom dggrid binary if needed.
# DGGRID_PATH=/home/appserv/.local/bin/dggrid

# Path to the TinyDB configuration file
dggs_api_config=/home/appserv/run/pydggsapi/server/config/dggs_api_config_example.json

# API Server Settings
PYDGDSAPI_HOST=0.0.0.0
PYDGDSAPI_PORT=8000
PYDGDSAPI_WORKERS=2
PYDGDSAPI_LOG_LEVEL=info

# Security & OGC API Settings
CORS='["*"]'
DGGS_PREFIX=/dggs-api/v1-pre
OPENAPI_URL=/dggs-api/v1-pre/openapi.json
DOCS_URL=/dggs-api/v1-pre/docs
